#!/bin/sh
# DUPLICATE: identical copy in every x-chip-os flavor (headless/gui/pocketchip) -- keep these in sync (no common/ dir; see README).

set -e

# original hook leaves an empty file,
# this borks ssh-keygen, because the empty file doesn't trigger the FirstBoot Condition
# but this special value will
printf 'uninitialized\n' > /etc/machine-id
